<!doctype html>
<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>Afghan Journal MB</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="/public/styles.css">
</head>
<body>
	<%- include('../partials/navbar') %>

	<main class="container my-5">
		<div class="p-5 bg-light rounded-4 border">
			<h1 class="display-5 fw-bold">Afghan Journal MB</h1>
			<p class="lead text-muted mb-4">
				Open-access repository for academic papers, theses, and reports. Search and explore research easily.
			</p>

			<form class="d-flex gap-2" method="get" action="/browse">
				<input class="form-control form-control-lg" name="q" placeholder="Search by title, author, abstract, or keyword..." />
				<button class="btn btn-dark btn-lg">Search</button>
			</form>
		</div>

		<h3 class="mt-5">Latest Approved Uploads</h3>
		<div class="row g-3 mt-2">
			<% if (!latest || latest.length === 0) { %>
				<p class="text-muted">No approved documents yet. Upload the first one!</p>
			<% } else { %>
				<% latest.forEach(d => { %>
					<div class="col-md-6 col-lg-4">
						<div class="card h-100">
							<div class="card-body">
								<div class="small text-muted"><%= d.category %> • <%= d.document_type %></div>
								<h5 class="card-title mt-2">
									<a href="/doc/<%= d.id %>"><%= d.title %></a>
								</h5>
								<div class="text-muted small"><%= d.authors %> <%= d.year ? ("• " + d.year) : "" %></div>
							</div>
						</div>
					</div>
				<% }) %>
			<% } %>
		</div>

		<h3 class="mt-5">Categories</h3>
		<div class="d-flex flex-wrap gap-2 mt-2">
			<% (categories || []).forEach(c => { %>
				<a class="btn btn-outline-secondary btn-sm" href="/browse?category=<%= c.slug %>"><%= c.name %></a>
			<% }) %>
		</div>
	</main>

	<%- include('../partials/footer') %>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
